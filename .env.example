# PostgreSQL Configuration
# When running in Docker, use:
#   - "host.docker.internal" if Postgres runs on the Docker host (macOS/Windows)
#   - the service name (e.g. "postgres") if Postgres runs in a sibling Compose service
#   - the hostname/IP for a remote server
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password

# ZDrive Configuration
ZDRIVE_KEY=your_drive_id
ZDRIVE_SECRET=your_drive_secret

# Optional: Custom Backup Filename Prefix
BACKUP_PREFIX=pg_backup

# Docker-only: Cron schedule (5-field cron syntax, evaluated in TZ).
# Leave empty to run once and exit (one-shot mode).
# Example: "30 20 * * *" = every day at 20:30.
CRON_SCHEDULE=30 20 * * *

# Docker-only: Timezone for cron and logs (e.g. UTC, Asia/Kolkata).
TZ=UTC
